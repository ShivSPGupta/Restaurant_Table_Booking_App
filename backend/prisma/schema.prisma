generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["restaurant_booking"]
}

model Reservation {
  id        String   @id @default(uuid())
  date      String
  time      String
  guests    Int
  name      String
  contact   String
  createdAt DateTime @default(now())

  @@unique([date, time])
  @@index([date])
  @@map("restaurant_booking_reservations")
  @@schema("restaurant_booking")
}

model Restaurant {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  address      String?
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([email])
  @@map("restaurant_booking_restaurants")
  @@schema("restaurant_booking")
}
