generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Reservation {
  id        String   @id @default(uuid())
  date      String
  time      String
  guests    Int
  name      String
  contact   String
  createdAt DateTime @default(now())

  @@unique([date, time])
  @@index([date])
}

model Restaurant {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  address      String?
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([email])
}
